{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server (Express)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "--env-file=../.env", "index.js"],
      "cwd": "server",
      "port": 3001
    },
    {
      "name": "UI (Vite / React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "client",
      "port": 5173
    },
    {
      "name": "Both (API + UI)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": ".",
      "port": 5173
    }
  ]
}
