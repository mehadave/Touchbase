# ── Server (Railway) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# From Supabase → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

PORT=3001
NODE_ENV=production
UPLOADS_DIR=./uploads

# ── Client (Vercel) ───────────────────────────────────────────────────────────
# From Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Railway API URL (set in Vercel env vars)
VITE_API_URL=https://your-railway-api.railway.app/api

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate with: node -e "import('web-push').then(m => console.log(m.default.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:you@example.com
# Also set on Vercel (client needs this to subscribe)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
